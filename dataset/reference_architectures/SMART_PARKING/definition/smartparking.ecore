<?xml version="1.0" encoding="ASCII"?>
<ecore:EPackage xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ecore="http://www.eclipse.org/emf/2002/Ecore" name="RA_Smart_Parking_Model">
  <eClassifiers xsi:type="ecore:EClass" name="Presentation_Layer">
    <eStructuralFeatures xsi:type="ecore:EReference" name="presentation_business" eType="//Business_Logic_Layer"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="presentation_security" eType="//Security"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="presentation_web_user_interface" eType="//Web_User_Interface"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="presentation_mobile_user_interface" eType="//Mobile_User_Interface"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="presentation_desktop_user_interface" eType="//Desktop_User_Interface"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Business_Logic_Layer">
    <eStructuralFeatures xsi:type="ecore:EReference" name="business_data" eType="//Data_Management_Layer"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="business_security" eType="//Security"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="business_navigation" eType="//Navigation"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="business_reservation" eType="//Reservation"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="business_administration" eType="//Administration"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="business_parking_map" eType="//Parking_Map"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="business_parking_lot" eType="//Parking_Lot"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="business_driver" eType="//Driver"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Data_Management_Layer">
    <eStructuralFeatures xsi:type="ecore:EReference" name="data_security" eType="//Security"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="data_data_acquisition" eType="//Data_Acquisition"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="data_data_processing" eType="//Data_Processing"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="data_decision_making" eType="//Decision_Making"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="data_data_storage" eType="//Data_Storage"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="data_data_visualisation" eType="//Data_Visualisation"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Security">
    <eStructuralFeatures xsi:type="ecore:EReference" name="security_presentation" eType="//Presentation_Layer"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="security_business" eType="//Business_Logic_Layer"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="security_data" eType="//Data_Management_Layer"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="security_confidentiality" eType="//Confidentiality"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="security_integrity" eType="//Integrity"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="security_availability" eType="//Availability"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Web_User_Interface"/>
  <eClassifiers xsi:type="ecore:EClass" name="Mobile_User_Interface"/>
  <eClassifiers xsi:type="ecore:EClass" name="Desktop_User_Interface"/>
  <eClassifiers xsi:type="ecore:EClass" name="Navigation"/>
  <eClassifiers xsi:type="ecore:EClass" name="Reservation"/>
  <eClassifiers xsi:type="ecore:EClass" name="Administration"/>
  <eClassifiers xsi:type="ecore:EClass" name="Parking_Map"/>
  <eClassifiers xsi:type="ecore:EClass" name="Parking_Lot"/>
  <eClassifiers xsi:type="ecore:EClass" name="Driver"/>
  <eClassifiers xsi:type="ecore:EClass" name="Data_Acquisition"/>
  <eClassifiers xsi:type="ecore:EClass" name="Data_Processing"/>
  <eClassifiers xsi:type="ecore:EClass" name="Decision_Making"/>
  <eClassifiers xsi:type="ecore:EClass" name="Data_Storage"/>
  <eClassifiers xsi:type="ecore:EClass" name="Data_Visualisation"/>
  <eClassifiers xsi:type="ecore:EClass" name="Confidentiality"/>
  <eClassifiers xsi:type="ecore:EClass" name="Integrity"/>
  <eClassifiers xsi:type="ecore:EClass" name="Availability"/>
  <eClassifiers xsi:type="ecore:EClass" name="RA_Smart_Parking_Model">
    <eStructuralFeatures xsi:type="ecore:EReference" name="presentation_layers" lowerBound="1" eType="//Presentation_Layer"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="business_logic_layers" lowerBound="1" eType="//Business_Logic_Layer"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="data_management_layers" lowerBound="1" eType="//Data_Management_Layer"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="securities" lowerBound="1" eType="//Security"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="web_user_interfaces" eType="//Web_User_Interface"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="mobile_user_interfaces" eType="//Mobile_User_Interface"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="desktop_user_interfaces" eType="//Desktop_User_Interface"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="navigations" eType="//Navigation"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="reservations" eType="//Reservation"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="administrations" eType="//Administration"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="parking_maps" eType="//Parking_Map"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="parking_lots" eType="//Parking_Lot"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="drivers" eType="//Driver"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="data_acquisitions" eType="//Data_Acquisition"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="data_processings" eType="//Data_Processing"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="decision_makings" eType="//Decision_Making"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="data_storages" eType="//Data_Storage"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="data_visualisations" eType="//Data_Visualisation"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="confidentialities" eType="//Confidentiality"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="integrities" eType="//Integrity"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="availabilities" eType="//Availability"/>
  </eClassifiers>
</ecore:EPackage>